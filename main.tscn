layout_mode = 2
tab_count = 1
tab_0/text = "All"

[node name="ScrollContainer" type="ScrollContainer" parent="VBoxContainer/InventoryPanel/VBox"]
layout_mode = 2
size_flags_vertical = 3
horizontal_scroll_mode = 0
vertical_scroll_mode = 2

[node name="MarginContainer" type="MarginContainer" parent="VBoxContainer/InventoryPanel/VBox/ScrollContainer"]
layout_mode = 2
size_flags_horizontal = 3
size_flags_vertical = 3
theme_override_constants/margin_left = 20
theme_override_constants/margin_top = 20
theme_override_constants/margin_right = 20
theme_override_constants/margin_bottom = 20

[node name="InventoryBox" type="GridContainer" parent="VBoxContainer/InventoryPanel/VBox/ScrollContainer/MarginContainer"]
